# Optional. API base URL including /api (e.g. https://api.example.com/api).
# In development: if unset, the app uses the same host as the Metro bundler so a
# physical device can reach your local backend (e.g. http://192.168.1.5:3001/api)
# without setting this. Set it only to override (e.g. different port or production).
# EXPO_PUBLIC_API_URL=http://localhost:3001/api
